generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Currency {
  code              String    @id @db.VarChar(10)
  name              String    @db.VarChar(100)
  symbol            String    @db.VarChar(10)
  exchangeRateToUsd Decimal   @map("exchange_rate_to_usd") @db.Decimal(14, 6)
  autoUpdate        Boolean   @default(true) @map("auto_update")
  lastUpdated       DateTime? @map("last_updated") @db.Timestamptz(6)
  bookings          Booking[]
  packages          Package[]
  payments          Payment[]
  regions           Region[]

  @@map("currencies")
}

model Region {
  id                      String                    @id @default(uuid()) @db.Uuid
  name                    String                    @db.VarChar(100)
  slug                    String                    @unique @db.VarChar(100)
  siteUrl                 String?                   @map("site_url") @db.VarChar(255)
  country                 String                    @db.VarChar(100)
  currencyCode            String                    @map("currency_code") @db.VarChar(10)
  languageCode            String                    @default("en") @map("language_code") @db.VarChar(10)
  contactEmail            String?                   @map("contact_email") @db.VarChar(255)
  contactPhone            String?                   @map("contact_phone") @db.VarChar(50)
  metaTitle               String?                   @map("meta_title") @db.VarChar(255)
  metaDescription         String?                   @map("meta_description")
  heroImageUrl            String?                   @map("hero_image_url") @db.VarChar(500)
  status                  String                    @default("draft") @db.VarChar(20)
  createdAt               DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  adminUserRegionAccess   AdminUserRegionAccess[]
  agents                  Agent[]
  bookings                Booking[]
  charterCompanies        CharterCompany[]
  customers               Customer[]
  leads                   Lead[]
  packageRegionVisibility PackageRegionVisibility[]
  yachtWebsiteVisibility  YachtWebsiteVisibility[]
  pricingRules            PricingRule[]
  promoCodes              PromoCode[]
  currency                Currency                  @relation(fields: [currencyCode], references: [code])
  yachts                  Yacht[]
  blogVisibility          BlogRegionVisibility[]

  @@map("regions")
}

model CharterCompany {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(255)
  logoUrl      String?  @map("logo_url") @db.VarChar(500)
  regionId     String   @map("region_id") @db.Uuid
  contactEmail String?  @map("contact_email") @db.VarChar(255)
  contactPhone String?  @map("contact_phone") @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  region       Region   @relation(fields: [regionId], references: [id])
  yachts       Yacht[]

  @@map("charter_companies")
}

model Yacht {
  id                 String                   @id @default(uuid()) @db.Uuid
  type               String                   @db.VarChar(50)
  status             String                   @default("available") @db.VarChar(30)
  createdAt          DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  beamM              Decimal?                 @map("beam_m") @db.Decimal(6, 2)
  capacityCrew       Int?                     @map("capacity_crew")
  capacityGuests     Int                      @map("capacity_guests")
  companyId          String                   @map("company_id") @db.Uuid
  cruiseSpeedKnots   Decimal?                 @map("cruise_speed_knots") @db.Decimal(5, 2)
  engineHp           Int?                     @map("engine_hp")
  engineType         String?                  @map("engine_type") @db.VarChar(100)
  fuelCapacityL      Int?                     @map("fuel_capacity_l")
  homePort           String?                  @map("home_port") @db.VarChar(255)
  isActive           Boolean                  @default(true) @map("is_active")
  lengthM            Decimal?                 @map("length_m") @db.Decimal(6, 2)
  name               String                   @db.VarChar(255)
  regionId           String                   @map("region_id") @db.Uuid
  yearBuilt          Int?                     @map("year_built")
  badge              String?                  @db.VarChar(100)
  bathrooms          String?                  @db.VarChar(20)
  boatType           String?                  @map("boat_type") @db.VarChar(50)
  built              String?                  @db.VarChar(100)
  cabins             String?                  @db.VarChar(20)
  capacity           String?                  @db.VarChar(100)
  charterType        String?                  @map("charter_type") @db.VarChar(50)
  code               String?                  @db.VarChar(50)
  cruisingSpeed      String?                  @map("cruising_speed") @db.VarChar(100)
  dayTripPrice       String?                  @map("day_trip_price") @db.VarChar(50)
  daytripPriceEuro   String?                  @map("daytrip_price_euro") @db.VarChar(50)
  design             String?                  @db.VarChar(255)
  displayOrder       Int?                     @map("display_order")
  fuelCapacity       String?                  @map("fuel_capacity") @db.VarChar(100)
  guests             String?                  @db.VarChar(20)
  guestsRange        String?                  @map("guests_range") @db.VarChar(20)
  length             String?                  @db.VarChar(50)
  lengthOverall      String?                  @map("length_overall") @db.VarChar(100)
  lengthRange        String?                  @map("length_range") @db.VarChar(50)
  overnightPrice     String?                  @map("overnight_price") @db.VarChar(50)
  passengerDayTrip   String?                  @map("passenger_day_trip") @db.VarChar(20)
  passengerOvernight String?                  @map("passenger_overnight") @db.VarChar(20)
  price              String?                  @db.VarChar(50)
  primaryImage       String?                  @map("primary_image") @db.VarChar(500)
  publicationStatus  String?                  @map("publication_status") @db.VarChar(30)
  slug               String?                  @unique @db.VarChar(255)
  sourceId           String?                  @unique @map("source_id") @db.VarChar(24)
  title              String?                  @db.VarChar(255)
  videoLink          String?                  @map("video_link") @db.VarChar(500)
  waterCapacity      String?                  @map("water_capacity") @db.VarChar(100)
  bookings               Booking[]
  leads                  Lead[]
  packages               Package[]
  amenities              YachtAmenity[]
  availabilityBlocks     YachtAvailabilityBlock[]
  documents              YachtDocument[]
  images                 YachtImage[]
  maintenance            YachtMaintenance[]
  tags                   YachtTag[]
  translations           YachtTranslation[]
  websiteVisibility      YachtWebsiteVisibility[]
  company                CharterCompany           @relation(fields: [companyId], references: [id])
  region                 Region                   @relation(fields: [regionId], references: [id])

  @@map("yachts")
}

model YachtImage {
  id        String   @id @default(uuid()) @db.Uuid
  yachtId   String   @map("yacht_id") @db.Uuid
  imageUrl  String   @map("image_url") @db.VarChar(500)
  caption   String?  @db.VarChar(255)
  isCover   Boolean  @default(false) @map("is_cover")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  yacht     Yacht    @relation(fields: [yachtId], references: [id], onDelete: Cascade)

  @@map("yacht_images")
}

model YachtTag {
  id        String   @id @default(uuid()) @db.Uuid
  yachtId   String   @map("yacht_id") @db.Uuid
  locale    String?  @db.VarChar(10)
  tag       String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  yacht     Yacht    @relation(fields: [yachtId], references: [id], onDelete: Cascade)

  @@unique([yachtId, locale, tag])
  @@map("yacht_tags")
}

model YachtTranslation {
  id               String   @id @default(uuid()) @db.Uuid
  yachtId          String   @map("yacht_id") @db.Uuid
  locale           String   @db.VarChar(10)
  slug             String?  @db.VarChar(255)
  title            String?  @db.VarChar(255)
  dayCharter       String?  @map("day_charter")
  overnightCharter String?  @map("overnight_charter")
  aboutThisBoat    String?  @map("about_this_boat")
  specifications   String?
  boatLayout       String?  @map("boat_layout")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  yacht            Yacht    @relation(fields: [yachtId], references: [id], onDelete: Cascade)

  @@unique([yachtId, locale])
  @@unique([locale, slug])
  @@map("yacht_translations")
}

model YachtAmenity {
  id          String  @id @default(uuid()) @db.Uuid
  yachtId     String  @map("yacht_id") @db.Uuid
  category    String  @db.VarChar(100)
  name        String  @db.VarChar(255)
  isAvailable Boolean @default(true) @map("is_available")
  yacht       Yacht   @relation(fields: [yachtId], references: [id], onDelete: Cascade)

  @@map("yacht_amenities")
}

model YachtDocument {
  id           String    @id @default(uuid()) @db.Uuid
  yachtId      String    @map("yacht_id") @db.Uuid
  documentType String    @map("document_type") @db.VarChar(100)
  documentUrl  String    @map("document_url") @db.VarChar(500)
  issuedDate   DateTime? @map("issued_date") @db.Date
  expiryDate   DateTime? @map("expiry_date") @db.Date
  isExpired    Boolean   @default(false) @map("is_expired")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  yacht        Yacht     @relation(fields: [yachtId], references: [id], onDelete: Cascade)

  @@map("yacht_documents")
}

model YachtMaintenance {
  id              String    @id @default(uuid()) @db.Uuid
  yachtId         String    @map("yacht_id") @db.Uuid
  maintenanceType String    @map("maintenance_type") @db.VarChar(100)
  description     String
  scheduledDate   DateTime  @map("scheduled_date") @db.Date
  completedDate   DateTime? @map("completed_date") @db.Date
  status          String    @default("scheduled") @db.VarChar(30)
  cost            Decimal?  @db.Decimal(10, 2)
  performedBy     String?   @map("performed_by") @db.VarChar(255)
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  yacht           Yacht     @relation(fields: [yachtId], references: [id], onDelete: Cascade)

  @@map("yacht_maintenance")
}

model YachtAvailabilityBlock {
  id        String   @id @default(uuid()) @db.Uuid
  yachtId   String   @map("yacht_id") @db.Uuid
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  reason    String?  @db.VarChar(100)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  yacht     Yacht    @relation(fields: [yachtId], references: [id], onDelete: Cascade)

  @@map("yacht_availability_blocks")
}

model Package {
  id               String                    @id @default(uuid()) @db.Uuid
  name             String                    @db.VarChar(255)
  description      String?
  yachtId          String?                   @map("yacht_id") @db.Uuid
  yachtCategory    String?                   @map("yacht_category") @db.VarChar(100)
  durationType     String                    @map("duration_type") @db.VarChar(30)
  durationHours    Decimal?                  @map("duration_hours") @db.Decimal(5, 2)
  durationDays     Int?                      @map("duration_days")
  basePrice        Decimal                   @map("base_price") @db.Decimal(10, 2)
  currencyCode     String                    @map("currency_code") @db.VarChar(10)
  maxCapacity      Int?                      @map("max_capacity")
  status           String                    @default("draft") @db.VarChar(20)
  isFeatured       Boolean                   @default(false) @map("is_featured")
  sortOrder        Int                       @default(0) @map("sort_order")
  createdAt        DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  bookings         Booking[]
  leads            Lead[]
  addons           PackageAddon[]
  includedServices PackageIncludedService[]
  media            PackageMedia[]
  regionVisibility PackageRegionVisibility[]
  currency         Currency                  @relation(fields: [currencyCode], references: [code])
  yacht            Yacht?                    @relation(fields: [yachtId], references: [id])
  pricingRules     PricingRule[]

  @@map("packages")
}

model PackageRegionVisibility {
  id        String  @id @default(uuid()) @db.Uuid
  packageId String  @map("package_id") @db.Uuid
  regionId  String  @map("region_id") @db.Uuid
  isVisible Boolean @default(true) @map("is_visible")
  sortOrder Int     @default(0) @map("sort_order")
  package   Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  region    Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@map("package_region_visibility")
}

model YachtWebsiteVisibility {
  id        String  @id @default(uuid()) @db.Uuid
  yachtId   String  @map("yacht_id") @db.Uuid
  regionId  String  @map("region_id") @db.Uuid
  isVisible Boolean @default(true) @map("is_visible")
  sortOrder Int     @default(0) @map("sort_order")
  yacht     Yacht   @relation(fields: [yachtId], references: [id], onDelete: Cascade)
  region    Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([yachtId, regionId])
  @@map("yacht_website_visibility")
}

model PackageIncludedService {
  id          String  @id @default(uuid()) @db.Uuid
  packageId   String  @map("package_id") @db.Uuid
  serviceName String  @map("service_name") @db.VarChar(100)
  isIncluded  Boolean @default(true) @map("is_included")
  notes       String? @db.VarChar(255)
  package     Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("package_included_services")
}

model PackageAddon {
  id            String         @id @default(uuid()) @db.Uuid
  packageId     String         @map("package_id") @db.Uuid
  name          String         @db.VarChar(255)
  description   String?
  price         Decimal        @db.Decimal(10, 2)
  priceType     String         @default("flat") @map("price_type") @db.VarChar(30)
  isActive      Boolean        @default(true) @map("is_active")
  sortOrder     Int            @default(0) @map("sort_order")
  bookingAddons BookingAddon[]
  package       Package        @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("package_addons")
}

model PackageMedia {
  id        String   @id @default(uuid()) @db.Uuid
  packageId String   @map("package_id") @db.Uuid
  mediaType String   @map("media_type") @db.VarChar(20)
  url       String   @db.VarChar(500)
  caption   String?  @db.VarChar(255)
  isCover   Boolean  @default(false) @map("is_cover")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@map("package_media")
}

model PricingRule {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(255)
  packageId       String?  @map("package_id") @db.Uuid
  regionId        String?  @map("region_id") @db.Uuid
  ruleType        String   @map("rule_type") @db.VarChar(30)
  multiplier      Decimal? @db.Decimal(5, 4)
  fixedAdjustment Decimal? @map("fixed_adjustment") @db.Decimal(10, 2)
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime @map("end_date") @db.Date
  priority        Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  package         Package? @relation(fields: [packageId], references: [id])
  region          Region?  @relation(fields: [regionId], references: [id])

  @@map("pricing_rules")
}

model PromoCode {
  id                 String    @id @default(uuid()) @db.Uuid
  code               String    @unique @db.VarChar(50)
  description        String?   @db.VarChar(255)
  discountType       String    @map("discount_type") @db.VarChar(20)
  discountValue      Decimal   @map("discount_value") @db.Decimal(10, 2)
  minBookingValue    Decimal?  @map("min_booking_value") @db.Decimal(10, 2)
  maxUses            Int?      @map("max_uses")
  usesCount          Int       @default(0) @map("uses_count")
  maxUsesPerCustomer Int       @default(1) @map("max_uses_per_customer")
  regionId           String?   @map("region_id") @db.Uuid
  validFrom          DateTime  @map("valid_from") @db.Timestamptz(6)
  validUntil         DateTime  @map("valid_until") @db.Timestamptz(6)
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  bookings           Booking[]
  region             Region?   @relation(fields: [regionId], references: [id])

  @@map("promo_codes")
}

model Agent {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  phone          String?   @db.VarChar(50)
  regionId       String    @map("region_id") @db.Uuid
  commissionRate Decimal   @map("commission_rate") @db.Decimal(5, 4)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  region         Region    @relation(fields: [regionId], references: [id])
  bookings       Booking[]

  @@map("agents")
}

model AdminUser {
  id                   String                  @id @default(uuid()) @db.Uuid
  firstName            String                  @map("first_name") @db.VarChar(100)
  lastName             String                  @map("last_name") @db.VarChar(100)
  email                String                  @unique @db.VarChar(255)
  passwordHash         String                  @map("password_hash") @db.VarChar(255)
  role                 String                  @default("agent") @db.VarChar(30)
  isActive             Boolean                 @default(true) @map("is_active")
  lastLogin            DateTime?               @map("last_login") @db.Timestamptz(6)
  passwordResetToken   String?                 @map("password_reset_token") @db.VarChar(255)
  passwordResetExpires DateTime?               @map("password_reset_expires") @db.Timestamptz(6)
  createdAt            DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  regionAccess         AdminUserRegionAccess[]
  auditLogs            AuditLog[]
  communicationLogs    CommunicationLog[]
  leads                Lead[]
  refreshTokens        RefreshToken[]

  @@map("admin_users")
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  adminUserId String    @map("admin_user_id") @db.Uuid
  tokenHash   String    @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model AdminUserRegionAccess {
  id              String    @id @default(uuid()) @db.Uuid
  adminUserId     String    @map("admin_user_id") @db.Uuid
  regionId        String    @map("region_id") @db.Uuid
  permissionLevel String    @default("view") @map("permission_level") @db.VarChar(20)
  adminUser       AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  region          Region    @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@map("admin_user_region_access")
}

model EmailTemplate {
  id                    String                 @id @default(uuid()) @db.Uuid
  name                  String                 @db.VarChar(255)
  type                  String                 @db.VarChar(100)
  subject               String                 @db.VarChar(255)
  bodyHtml              String                 @map("body_html")
  bodyText              String?                @map("body_text")
  isActive              Boolean                @default(true) @map("is_active")
  updatedAt             DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  followUpSequenceSteps FollowUpSequenceStep[]

  @@map("email_templates")
}

model Customer {
  id                String             @id @default(uuid()) @db.Uuid
  firstName         String             @map("first_name") @db.VarChar(100)
  lastName          String             @map("last_name") @db.VarChar(100)
  email             String             @unique @db.VarChar(255)
  phone             String?            @db.VarChar(50)
  whatsapp          String?            @db.VarChar(50)
  country           String?            @db.VarChar(100)
  regionId          String?            @map("region_id") @db.Uuid
  segment           String             @default("new") @db.VarChar(30)
  loyaltyTier       String             @default("bronze") @map("loyalty_tier") @db.VarChar(30)
  loyaltyPoints     Int                @default(0) @map("loyalty_points")
  source            String?            @db.VarChar(100)
  notes             String?
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  bookings          Booking[]
  communicationLogs CommunicationLog[]
  surveys           CustomerSurvey[]
  tags              CustomerTag[]
  region            Region?            @relation(fields: [regionId], references: [id])
  leads             Lead[]

  @@map("customers")
}

model CustomerTag {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  tag        String   @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_tags")
}

model Booking {
  id                 String           @id @default(uuid()) @db.Uuid
  bookingRef         String           @unique @map("booking_ref") @db.VarChar(20)
  customerId         String           @map("customer_id") @db.Uuid
  yachtId            String           @map("yacht_id") @db.Uuid
  packageId          String           @map("package_id") @db.Uuid
  regionId           String           @map("region_id") @db.Uuid
  agentId            String?          @map("agent_id") @db.Uuid
  startDate          DateTime         @map("start_date") @db.Date
  endDate            DateTime         @map("end_date") @db.Date
  startTime          String?          @map("start_time") @db.VarChar(20)
  guestCount         Int              @map("guest_count")
  status             String           @default("inquiry") @db.VarChar(30)
  baseAmount         Decimal          @map("base_amount") @db.Decimal(10, 2)
  addonsAmount       Decimal          @default(0) @map("addons_amount") @db.Decimal(10, 2)
  discountAmount     Decimal          @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount          Decimal          @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount        Decimal          @map("total_amount") @db.Decimal(10, 2)
  currencyCode       String           @map("currency_code") @db.VarChar(10)
  promoCodeId        String?          @map("promo_code_id") @db.Uuid
  cancellationPolicy String?          @map("cancellation_policy") @db.VarChar(50)
  cancellationReason String?          @map("cancellation_reason")
  cancelledAt        DateTime?        @map("cancelled_at") @db.Timestamptz(6)
  specialRequests    String?          @map("special_requests")
  internalNotes      String?          @map("internal_notes")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  addons             BookingAddon[]
  agent              Agent?           @relation(fields: [agentId], references: [id])
  currency           Currency         @relation(fields: [currencyCode], references: [code])
  customer           Customer         @relation(fields: [customerId], references: [id])
  package            Package          @relation(fields: [packageId], references: [id])
  promoCode          PromoCode?       @relation(fields: [promoCodeId], references: [id])
  region             Region           @relation(fields: [regionId], references: [id])
  yacht              Yacht            @relation(fields: [yachtId], references: [id])
  surveys            CustomerSurvey[]
  leads              Lead[]
  payments           Payment[]

  @@map("bookings")
}

model BookingAddon {
  id         String       @id @default(uuid()) @db.Uuid
  bookingId  String       @map("booking_id") @db.Uuid
  addonId    String       @map("addon_id") @db.Uuid
  quantity   Int          @default(1)
  unitPrice  Decimal      @map("unit_price") @db.Decimal(10, 2)
  totalPrice Decimal      @map("total_price") @db.Decimal(10, 2)
  addon      PackageAddon @relation(fields: [addonId], references: [id])
  booking    Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_addons")
}

model Payment {
  id            String    @id @default(uuid()) @db.Uuid
  bookingId     String    @map("booking_id") @db.Uuid
  amount        Decimal   @db.Decimal(10, 2)
  currencyCode  String    @map("currency_code") @db.VarChar(10)
  paymentType   String    @map("payment_type") @db.VarChar(30)
  paymentMethod String?   @map("payment_method") @db.VarChar(50)
  status        String    @default("pending") @db.VarChar(30)
  gatewayRef    String?   @map("gateway_ref") @db.VarChar(255)
  paidAt        DateTime? @map("paid_at") @db.Timestamptz(6)
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  booking       Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  currency      Currency  @relation(fields: [currencyCode], references: [code])

  @@map("payments")
}

model Lead {
  id                 String     @id @default(uuid()) @db.Uuid
  customerId         String?    @map("customer_id") @db.Uuid
  regionId           String     @map("region_id") @db.Uuid
  packageId          String?    @map("package_id") @db.Uuid
  yachtId            String?    @map("yacht_id") @db.Uuid
  status             String     @default("new") @db.VarChar(30)
  source             String?    @db.VarChar(100)
  notes              String?
  assignedTo         String?    @map("assigned_to") @db.Uuid
  convertedBookingId String?    @map("converted_booking_id") @db.Uuid
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignedToUser     AdminUser? @relation(fields: [assignedTo], references: [id])
  convertedBooking   Booking?   @relation(fields: [convertedBookingId], references: [id])
  customer           Customer?  @relation(fields: [customerId], references: [id])
  package            Package?   @relation(fields: [packageId], references: [id])
  region             Region     @relation(fields: [regionId], references: [id])
  yacht              Yacht?     @relation(fields: [yachtId], references: [id])

  @@map("leads")
}

model CommunicationLog {
  id          String     @id @default(uuid()) @db.Uuid
  customerId  String     @map("customer_id") @db.Uuid
  channel     String     @db.VarChar(30)
  direction   String     @db.VarChar(10)
  subject     String?    @db.VarChar(255)
  body        String?
  adminUserId String?    @map("admin_user_id") @db.Uuid
  loggedAt    DateTime   @default(now()) @map("logged_at") @db.Timestamptz(6)
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("communication_logs")
}

model CustomerSurvey {
  id            String   @id @default(uuid()) @db.Uuid
  bookingId     String   @map("booking_id") @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  overallRating Int      @map("overall_rating")
  yachtRating   Int      @map("yacht_rating")
  crewRating    Int      @map("crew_rating")
  valueRating   Int      @map("value_rating")
  comment       String?
  isPublic      Boolean  @default(false) @map("is_public")
  submittedAt   DateTime @default(now()) @map("submitted_at") @db.Timestamptz(6)
  booking       Booking  @relation(fields: [bookingId], references: [id])
  customer      Customer @relation(fields: [customerId], references: [id])

  @@map("customer_surveys")
}

model FollowUpSequence {
  id           String                 @id @default(uuid()) @db.Uuid
  name         String                 @db.VarChar(255)
  triggerEvent String                 @map("trigger_event") @db.VarChar(100)
  isActive     Boolean                @default(true) @map("is_active")
  createdAt    DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  steps        FollowUpSequenceStep[]

  @@map("follow_up_sequences")
}

model FollowUpSequenceStep {
  id         String           @id @default(uuid()) @db.Uuid
  sequenceId String           @map("sequence_id") @db.Uuid
  stepOrder  Int              @map("step_order")
  delayDays  Int              @map("delay_days")
  channel    String           @db.VarChar(30)
  templateId String?          @map("template_id") @db.Uuid
  subject    String?          @db.VarChar(255)
  sequence   FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  template   EmailTemplate?   @relation(fields: [templateId], references: [id])

  @@map("follow_up_sequence_steps")
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  adminUserId String    @map("admin_user_id") @db.Uuid
  action      String    @db.VarChar(30)
  module      String    @db.VarChar(100)
  entityType  String    @map("entity_type") @db.VarChar(100)
  entityId    String?   @map("entity_id") @db.Uuid
  description String?
  ipAddress   String?   @map("ip_address") @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])

  @@map("audit_logs")
}

// ─── Blog ─────────────────────────────────────────────────────────────────────

model Blog {
  id               String                  @id @default(uuid()) @db.Uuid
  slug             String                  @unique @db.VarChar(255)
  title            String?                 @db.VarChar(255)
  shortDescription String?                 @map("short_description")
  detailedDescription String?              @map("detailed_description")
  primaryImage     String?                 @map("primary_image") @db.VarChar(500)
  primaryImageKey  String?                 @map("primary_image_key") @db.VarChar(500)
  status           String                  @default("draft") @db.VarChar(20)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  translations     BlogTranslation[]
  regionVisibility BlogRegionVisibility[]

  @@map("blogs")
}

model BlogRegionVisibility {
  id        String  @id @default(uuid()) @db.Uuid
  blogId    String  @map("blog_id") @db.Uuid
  regionId  String  @map("region_id") @db.Uuid
  blog      Blog    @relation(fields: [blogId], references: [id], onDelete: Cascade)
  region    Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([blogId, regionId])
  @@map("blog_region_visibility")
}

model BlogTranslation {
  id                  String   @id @default(uuid()) @db.Uuid
  blogId              String   @map("blog_id") @db.Uuid
  locale              String   @db.VarChar(10)
  title               String?  @db.VarChar(255)
  shortDescription    String?  @map("short_description")
  detailedDescription String?  @map("detailed_description")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  blog                Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  @@unique([blogId, locale])
  @@map("blog_translations")
}
