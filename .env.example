# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Prisma uses DATABASE_URL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/faraway_admin?schema=public"

# JWT (use strong random secrets in production)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Resend (password reset emails) - https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM=YachtOS Admin <noreply@yourdomain.com>
# Base URL for reset link (e.g. frontend app). Link: ${FRONTEND_URL}/reset-password?token=...
FRONTEND_URL=http://localhost:3000

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-bucket-name
# Optional: Public URL or CDN URL for accessing files (if bucket is public or behind CDN)
AWS_S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com
# Default ACL: private | public-read | authenticated-read
AWS_S3_DEFAULT_ACL=private
# Max file size in bytes (default: 10485760 = 10MB)
AWS_S3_MAX_FILE_SIZE=10485760
# Comma-separated allowed MIME types (empty = allow all)
# AWS_S3_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Optional: in development, forgot-password can return reset token in response (for testing)
# RETURN_RESET_TOKEN=true
